{
  "rewrites": [
    {
      "source": "/((?!assets|sw.js|manifest.json|icon|favicon|intro).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
